DATABASE_URL=postgresql://user:pass@localhost:5432/mcp
REDIS_URL=redis://localhost:6379
JWT_SECRET=changeme-replace-with-32-byte-random-hex
DOCKER_HOST=unix:///var/run/docker.sock

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# Supabase S3-compatible storage — https://supabase.com/dashboard/project/_/settings/storage
SUPABASE_S3_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
